# Postgres connection string.
# Supabase → Project Settings → Database → Connection string.
# Prefer the "Session pooler" URI (IPv4-friendly, works on Render/Fly/Railway).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Supabase project URL — used to fetch the JWKS that verifies Auth JWTs.
# NO trailing slash (the code appends /auth/v1/.well-known/jwks.json).
SUPABASE_URL=https://<project-ref>.supabase.co

# Allowed frontend origin(s) for CORS, comma-separated.
# Local dev = http://localhost:3000. In prod set to your Vercel URL,
# e.g. https://curio.vercel.app
FRONTEND_URL=http://localhost:3000

# Port to bind. Hosts inject this automatically; defaults to 8080 locally.
# PORT=8080
